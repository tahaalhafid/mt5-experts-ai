{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atas.context_packet_core.v1",
  "title": "ATAS Context Packet Core V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_family",
    "packet_id",
    "trace_id",
    "emitted_at_utc",
    "event_time_utc",
    "fresh_until_utc",
    "source_binding",
    "quality_confidence",
    "microstructure_observation",
    "cross_instrument_basis_evidence",
    "governance_flags"
  ],
  "properties": {
    "schema_version": {
      "const": "ATAS_CONTEXT_PACKET_CORE_V1"
    },
    "packet_family": {
      "const": "context_packet_core"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "emitted_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "event_time_utc": {
      "type": "string",
      "format": "date-time"
    },
    "fresh_until_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_platform",
        "source_mode",
        "source_symbol",
        "source_symbol_original",
        "execution_symbol"
      ],
      "properties": {
        "source_platform": {
          "type": "string"
        },
        "source_mode": {
          "type": "string",
          "enum": [
            "LIVE",
            "REPLAY",
            "SYNTHETIC",
            "UNKNOWN"
          ]
        },
        "source_symbol": {
          "type": "string"
        },
        "source_symbol_original": {
          "type": "string"
        },
        "execution_symbol": {
          "type": "string"
        }
      }
    },
    "quality_confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality_state",
        "packet_confidence",
        "signal_stability_window_sec"
      ],
      "properties": {
        "quality_state": {
          "type": "string",
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW",
            "UNKNOWN"
          ]
        },
        "packet_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "signal_stability_window_sec": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "microstructure_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "liquidity_sweep_state",
        "absorption_state",
        "delta_bias_state",
        "imbalance_state",
        "liquidity_stability_state",
        "continuation_exhaustion_hint"
      ],
      "properties": {
        "liquidity_sweep_state": {
          "type": "string"
        },
        "absorption_state": {
          "type": "string"
        },
        "delta_bias_state": {
          "type": "string"
        },
        "imbalance_state": {
          "type": "string"
        },
        "liquidity_stability_state": {
          "type": "string"
        },
        "continuation_exhaustion_hint": {
          "type": "string"
        }
      }
    },
    "cross_instrument_basis_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_reference_price",
        "execution_reference_price",
        "cross_instrument_basis_value",
        "cross_instrument_translation_applied",
        "price_anchor_fields_suppressed",
        "suppression_reason_codes"
      ],
      "properties": {
        "source_reference_price": {
          "type": [
            "number",
            "null"
          ]
        },
        "execution_reference_price": {
          "type": [
            "number",
            "null"
          ]
        },
        "cross_instrument_basis_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "cross_instrument_translation_applied": {
          "type": "boolean"
        },
        "price_anchor_fields_suppressed": {
          "type": "boolean"
        },
        "suppression_reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "governance_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_class",
        "non_authoritative",
        "mt5_runtime_authority_required",
        "semantic_adapter_required"
      ],
      "properties": {
        "authority_class": {
          "const": "EXTERNAL_NON_AUTHORITATIVE_CONTEXT_PACKET"
        },
        "non_authoritative": {
          "const": true
        },
        "mt5_runtime_authority_required": {
          "const": true
        },
        "semantic_adapter_required": {
          "const": true
        }
      }
    }
  }
}
