{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atas.recent_diagnostics_snapshot.v1",
  "title": "ATAS Recent Diagnostics Snapshot V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_family",
    "snapshot_timestamp_utc",
    "chain_state",
    "freshness_state",
    "attachment_state",
    "advisory_eligibility_state"
  ],
  "properties": {
    "schema_version": {
      "const": "ATAS_RECENT_DIAGNOSTICS_SNAPSHOT_V1"
    },
    "packet_family": {
      "const": "recent_diagnostics_snapshot"
    },
    "snapshot_timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "chain_state": {
      "type": "string"
    },
    "freshness_state": {
      "type": "string"
    },
    "attachment_state": {
      "type": "string"
    },
    "advisory_eligibility_state": {
      "type": "string"
    },
    "first_failing_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage",
        "reason_code"
      ],
      "properties": {
        "stage": {
          "type": "string"
        },
        "reason_code": {
          "type": "string"
        }
      }
    },
    "packet_progression_summary": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
